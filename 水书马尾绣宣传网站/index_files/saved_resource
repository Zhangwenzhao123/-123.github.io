  a.file {
    background : url("data:image/png;base64,") left top no-repeat;
  }

  a.dir {
    background : url("data:image/png;base64,") left top no-repeat;
  }

  a.up {
    background : url("data:image/png;base64,") left top no-repeat;
  }

  html[dir=rtl] a {
    background-position-x: right;
  }

  #parentDirLinkBox {
    margin-bottom: 10px;
    padding-bottom: 10px;
  }
</style>

